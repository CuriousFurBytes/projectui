{
  "name": "projectui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ProjecTUI — visually design terminal UIs in the browser and export runnable code for Textual (Python), Bubble Tea (Go), or Ratatui (Rust).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:docs",
    "build:docs": "mkdir -p docs-src/public/screenshots && (cp -r e2e/screenshots/. docs-src/public/screenshots/ 2>/dev/null || true) && vitepress build docs-src",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:css": "stylelint 'src/**/*.css'",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.49",
    "stylelint": "^16.0.0",
    "vitepress": "^1.3.4",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix --max-warnings=0"],
    "*.css": ["stylelint --fix"]
  }
}
